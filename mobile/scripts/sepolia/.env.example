# Sepolia E2E Test Configuration
# Copy this file to .env and fill in your values

# ============================================================================
# Test Wallets
# ============================================================================

# Primary test wallet (Wallet A)
# Get testnet ETH from: https://sepoliafaucet.com/
TEST_PRIVKEY_A=0x1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef

# Secondary test wallet (Wallet B) - for split bill incoming tests
TEST_PRIVKEY_B=0xabcdef1234567890abcdef1234567890abcdef1234567890abcdef1234567890

# Recipient addresses for split bill tests (3 participants)
TEST_RECIPIENT_1=0x742d35Cc6634C0532925a3b844Bc9e7595f0bEb
TEST_RECIPIENT_2=0x3C44CdDdB6a900fa2b585dd299e03d12FA4293BC
TEST_RECIPIENT_3=0x90F79bf6EB2c4f870365E785982E1f101E93b906

# ============================================================================
# Token Configuration
# ============================================================================

# ERC-20 token address on Sepolia
# Sepolia USDC: 0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238
# Sepolia DAI: 0x68194a729C2450ad26072b3D33ADaCbcef39D574
TEST_TOKEN_ADDRESS=0x1c7D4B196Cb0C7B01d743Fbc6116a902379C7238

# ============================================================================
# Network Configuration
# ============================================================================

# RPC URL (optional, defaults to public Sepolia RPC)
# Public: https://rpc.sepolia.org
# Infura: https://sepolia.infura.io/v3/YOUR_KEY
# Alchemy: https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
SEPOLIA_RPC_URL=https://rpc.sepolia.org

# Rate limiting (milliseconds between requests)
RPC_RATE_LIMIT_MS=1000

# Confirmation threshold
MIN_CONFIRMATIONS=2

# Test timeouts (milliseconds)
TEST_TIMEOUT_MS=300000              # 5 minutes per test
TRANSACTION_TIMEOUT_MS=120000       # 2 minutes per transaction
BLOCK_WAIT_TIMEOUT_MS=60000         # 1 minute for block confirmations
