# Mainnet Smoke Test Configuration
# ⚠️  WARNING: NEVER commit this file with real values!
# ⚠️  Use dedicated test wallet with minimal funds only!

# ============================================================================
# Wallet Configuration
# ============================================================================

# Private key for mainnet smoke tests
# ⚠️  NEVER use your main wallet! Create a dedicated test wallet!
# ⚠️  Fund with minimal ETH only (e.g., 0.01 ETH)
MAINNET_PRIVKEY=0x1234567890abcdef1234567890abcdef1234567890abcdef1234567890abcdef

# ============================================================================
# Split Bill Recipients
# ============================================================================

# Recipient addresses for split bill smoke test
# Use trusted addresses (e.g., your other wallets)
SPLIT_RECIPIENT_1=0x742d35Cc6634C0532925a3b844Bc9e7595f0bEb
SPLIT_RECIPIENT_2=0x3C44CdDdB6a900fa2b585dd299e03d12FA4293BC

# ============================================================================
# Network Configuration
# ============================================================================

# Mainnet RPC URL
# Public: https://eth.llamarpc.com
# Infura: https://mainnet.infura.io/v3/YOUR_KEY
# Alchemy: https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY
MAINNET_RPC_URL=https://eth.llamarpc.com

# ============================================================================
# Safety Settings
# ============================================================================

# Minimum confirmations to wait (1-2 for smoke tests)
MIN_CONFIRMATIONS=1

# Maximum gas price in Gwei (safety limit)
MAX_GAS_PRICE_GWEI=100

# ============================================================================
# Feature Flags
# ============================================================================

# Enable scheduled payments on mainnet
# ⚠️  Only set to true after smoke tests pass!
SCHEDULE_MAINNET_ENABLED=false

# Enable split bills on mainnet
# ⚠️  Only set to true after smoke tests pass!
SPLIT_MAINNET_ENABLED=false

# ============================================================================
# SAFETY CHECKLIST
# ============================================================================

# Before running smoke tests:
# [ ] Using dedicated test wallet (not main wallet)
# [ ] Wallet funded with minimal ETH only (< 0.01 ETH)
# [ ] Recipients are trusted addresses
# [ ] Network is confirmed as mainnet (chain ID 1)
# [ ] Gas price is reasonable (< 100 Gwei)
# [ ] Manual confirmation enabled in scripts
# [ ] Team notified about smoke test
# [ ] Ready to monitor transactions on Etherscan

# After smoke tests pass:
# [ ] Both smoke tests executed successfully twice
# [ ] Transaction hashes logged and verified
# [ ] Gas costs within expected range
# [ ] No errors or reverts
# [ ] Feature flags can be enabled
