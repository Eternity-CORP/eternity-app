{
  "name": "mobile",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "version:patch": "npm version patch --no-git-tag-version && node scripts/bump-build-number.js",
    "version:minor": "npm version minor --no-git-tag-version && node scripts/bump-build-number.js",
    "version:major": "npm version major --no-git-tag-version && node scripts/bump-build-number.js",
    "build:dev": "eas build --profile development --platform all",
    "build:preview": "eas build --profile preview --platform all",
    "build:beta": "eas build --profile beta --platform all",
    "build:prod": "eas build --profile production --platform all",
    "build:ios:dev": "eas build --profile development --platform ios",
    "build:ios:prod": "eas build --profile production --platform ios",
    "build:android:dev": "eas build --profile development --platform android",
    "build:android:prod": "eas build --profile production --platform android",
    "submit:beta": "eas submit --profile beta --platform all",
    "submit:prod": "eas submit --profile production --platform all",
    "release:patch": "npm run version:patch && npm run build:prod",
    "release:minor": "npm run version:minor && npm run build:prod",
    "release:major": "npm run version:major && npm run build:prod",
    "release-notes": "node scripts/generate-release-notes.js",
    "prebuild": "expo prebuild",
    "update:dev": "eas update --branch dev --message 'Dev update'",
    "update:beta": "eas update --branch beta --message 'Beta update'",
    "update:prod": "eas update --branch production --message 'Production update'",
    "security:check": "./scripts/sca-check.sh",
    "security:fix": "./scripts/sca-check.sh --fix",
    "security:test": "./scripts/test-vulnerable-dependency.sh",
    "security:audit": "npm audit --audit-level=moderate",
    "security:licenses": "npx license-checker --summary",
    "test:sepolia": "vitest run scripts/sepolia/",
    "test:sepolia:watch": "vitest scripts/sepolia/",
    "test:sepolia:eth": "vitest run scripts/sepolia/send-eth.spec.ts",
    "test:sepolia:erc20": "vitest run scripts/sepolia/send-erc20.spec.ts",
    "anvil:reset": "ts-node scripts/anvil/reset.ts",
    "test:anvil": "vitest run scripts/anvil/",
    "test:anvil:watch": "vitest scripts/anvil/",
    "test:anvil:eth": "vitest run scripts/anvil/send-eth.spec.ts",
    "test:anvil:erc20": "vitest run scripts/anvil/send-erc20.spec.ts",
    "mainnet:smoke": "ts-node scripts/mainnet/smoke-send-eth.ts"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-navigation/native": "~7.1.0",
    "@react-navigation/native-stack": "~7.5.0",
    "crypto-js": "^4.2.0",
    "ethers": "^5.7.2",
    "expo": "~54.0.20",
    "expo-clipboard": "~8.0.7",
    "expo-haptics": "^15.0.8",
    "expo-linear-gradient": "~15.0.7",
    "expo-linking": "~8.0.8",
    "expo-local-authentication": "~17.0.7",
    "expo-localization": "^17.0.7",
    "expo-notifications": "~0.32.12",
    "expo-screen-capture": "^8.0.8",
    "expo-secure-store": "~15.0.7",
    "expo-sensors": "~15.0.8",
    "expo-status-bar": "~3.0.8",
    "expo-updates": "~29.0.12",
    "i18next": "^25.6.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-i18next": "^16.2.4",
    "react-native": "0.81.5",
    "react-native-confetti-cannon": "^1.5.2",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-get-random-values": "~1.11.0",
    "react-native-qrcode-svg": "^6.3.15",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-webview": "13.15.0",
    "react-native-worklets": "0.5.1",
    "rrule": "^2.8.1",
    "uuid": "^13.0.0",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "jest": "^29.7.0",
    "jest-expo": "^54.0.13",
    "typescript": "~5.9.2"
  },
  "overrides": {
    "react-native-screens": "~4.16.0"
  },
  "private": true
}
