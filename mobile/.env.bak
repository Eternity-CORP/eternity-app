# Environment configuration for Eternity Wallet (Expo SDK)
# Only variables prefixed with EXPO_PUBLIC_ are available in the app runtime.
# Do NOT put secrets here; these are bundled client-side.

# Default network: "mainnet", "sepolia", or "holesky"
EXPO_PUBLIC_DEFAULT_NETWORK=sepolia

# Storage key names for SecureStore/localStorage (not secrets; just key names)
EXPO_PUBLIC_STORAGE_SEED_KEY=eternity-wallet-seed
EXPO_PUBLIC_STORAGE_PRIVATE_KEY=eternity-wallet-privatekey
EXPO_PUBLIC_STORAGE_ENC_KEY_KEY=eternity-wallet-key
EXPO_PUBLIC_STORAGE_WALLET_META_KEY=eternity-wallet-meta

# Provider URLs (set one or more; leave empty to use public fallbacks)
EXPO_PUBLIC_ALCHEMY_MAINNET_URL=https://eth-mainnet.g.alchemy.com/v2/***REDACTED_ALCHEMY_KEY***
EXPO_PUBLIC_ALCHEMY_SEPOLIA_URL=https://eth-sepolia.g.alchemy.com/v2/***REDACTED_ALCHEMY_KEY***
EXPO_PUBLIC_ALCHEMY_HOLESKY_URL=https://eth-holesky.g.alchemy.com/v2/***REDACTED_ALCHEMY_KEY***
EXPO_PUBLIC_INFURA_MAINNET_URL=
EXPO_PUBLIC_INFURA_SEPOLIA_URL=
EXPO_PUBLIC_INFURA_HOLESKY_URL=

# Public fallback RPCs (can be overridden if desired)
EXPO_PUBLIC_PUBLIC_MAINNET_URL=https://ethereum-rpc.publicnode.com
EXPO_PUBLIC_PUBLIC_SEPOLIA_URL=https://rpc.sepolia.org
EXPO_PUBLIC_PUBLIC_HOLESKY_URL=https://ethereum-holesky-rpc.publicnode.com

# Etherscan API key for transaction history (get free key at https://etherscan.io/myapikey)
EXPO_PUBLIC_ETHERSCAN_API_KEY=***REDACTED_ETHERSCAN_KEY***

# ============================================================================
# MAINNET SAFETY CONTROLS
# ============================================================================

# Enable mainnet transactions (MUST be explicitly enabled)
# WARNING: Only enable after completing prod-checklist.md
EXPO_PUBLIC_MAINNET_ENABLED=false

# Maximum transaction amount on mainnet (in ETH)
# Prevents accidental large transfers
EXPO_PUBLIC_MAINNET_MAX_AMOUNT=0.1

# Require confirmation for mainnet transactions
EXPO_PUBLIC_MAINNET_REQUIRE_CONFIRMATION=true

EXPO_PUBLIC_API_BASE_URL=http://192.168.50.28:3000/api

