{
  "name": "@e-y/mobile",
  "main": "expo-router/entry",
  "version": "0.1.0",
  "scripts": {
    "start": "expo start --dev-client",
    "start:go": "expo start",
    "android": "expo start --android --dev-client",
    "ios": "expo start --ios --dev-client",
    "web": "expo start --web",
    "dev": "expo start --dev-client",
    "build": "expo export",
    "typecheck": "tsc --noEmit",
    "eas-build-pre-install": "cd ../.. && corepack enable && corepack prepare pnpm@8.15.0 --activate && pnpm install",
    "eas-build-post-install": "cd ../.. && pnpm --filter @e-y/shared build && pnpm --filter @e-y/crypto build"
  },
  "dependencies": {
    "@e-y/shared": "workspace:*",
    "@e-y/crypto": "workspace:*",
    "@expo/vector-icons": "^15.0.3",
    "@react-navigation/native": "^7.1.8",
    "@reduxjs/toolkit": "^2.2.0",
    "ethers": "^6.16.0",
    "expo": "~54.0.31",
    "expo-camera": "~17.0.0",
    "expo-clipboard": "~8.0.0",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.0",
    "expo-font": "~14.0.10",
    "expo-haptics": "~15.0.0",
    "expo-linking": "~8.0.11",
    "expo-local-authentication": "~17.0.0",
    "expo-router": "~6.0.21",
    "expo-secure-store": "~15.0.0",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-web": "~0.21.0",
    "react-redux": "^9.1.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@types/react": "~19.1.0",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
