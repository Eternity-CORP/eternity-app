{
  "name": "@e-y/mobile",
  "main": "expo-router/entry",
  "version": "0.1.0",
  "scripts": {
    "start": "expo start --dev-client",
    "start:go": "expo start",
    "android": "expo start --android --dev-client",
    "ios": "expo start --ios --dev-client",
    "web": "expo start --web",
    "dev": "expo start --dev-client",
    "build": "expo export",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "eas-build-pre-install": "cd ../.. && corepack enable && corepack prepare pnpm@9.1.0 --activate && pnpm install",
    "eas-build-post-install": "cd ../.. && pnpm --filter @e-y/shared build && pnpm --filter @e-y/crypto build"
  },
  "dependencies": {
    "@e-y/crypto": "workspace:*",
    "@e-y/shared": "workspace:*",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "^8.4.4",
    "@react-navigation/native": "^7.1.8",
    "@reduxjs/toolkit": "^2.2.0",
    "@sentry/react-native": "^7.2.0",
    "ethers": "^6.16.0",
    "expo": "~54.0.32",
    "expo-blur": "~15.0.8",
    "expo-camera": "~17.0.10",
    "expo-clipboard": "~8.0.0",
    "expo-constants": "~18.0.13",
    "expo-dev-client": "~6.0.0",
    "expo-device": "^8.0.10",
    "expo-file-system": "^19.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.0",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-local-authentication": "~17.0.0",
    "expo-notifications": "^0.32.16",
    "expo-router": "~6.0.22",
    "expo-secure-store": "~15.0.0",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-draggable-flatlist": "^4.0.3",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-get-random-values": "^1.11.0",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "^15.12.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1",
    "react-redux": "^9.1.0",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/react": "~19.1.0",
    "jest": "^29.7.0",
    "react-test-renderer": "19.1.0",
    "ts-jest": "^29.1.2",
    "typescript": "~5.9.2"
  },
  "private": true
}
