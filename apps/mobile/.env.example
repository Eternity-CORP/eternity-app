# RPC Provider Configuration
# Copy this file to .env and fill in your API keys

# Alchemy API Key (Primary RPC Provider)
EXPO_PUBLIC_ALCHEMY_API_KEY=your_alchemy_api_key_here

# Infura API Key (Fallback RPC Provider)
EXPO_PUBLIC_INFURA_API_KEY=your_infura_api_key_here

# Network: 'sepolia' for testnet, 'mainnet' for production
EXPO_PUBLIC_NETWORK=sepolia

# Backend API URL (optional - auto-detected in development)
# In development with Expo Go, the app automatically detects the host IP
# Set this explicitly for production or when auto-detection fails
# EXPO_PUBLIC_API_URL=http://your-backend-server:3000
