{
  "expo": {
    "name": "E-Y",
    "slug": "e-y",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "ey",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.eternity.wallet",
      "buildNumber": "1",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "E-Y needs camera access to scan QR codes for wallet addresses and payments.",
        "NSFaceIDUsageDescription": "E-Y uses Face ID to secure access to your wallet.",
        "NSMicrophoneUsageDescription": "E-Y uses the microphone for voice input."
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#000000"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.eternity.wallet",
      "versionCode": 1,
      "permissions": [
        "CAMERA",
        "VIBRATE",
        "USE_BIOMETRIC",
        "USE_FINGERPRINT"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "E-Y needs camera access to scan QR codes for wallet addresses and payments."
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#5E6AD2",
          "sounds": []
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "E-Y uses Face ID to secure access to your wallet."
        }
      ],
      "expo-secure-store",
      "@react-native-community/datetimepicker",
      "expo-font",
      [
        "expo-speech-recognition",
        {
          "microphonePermission": "Allow E-Y to use the microphone for voice input.",
          "speechRecognitionPermission": "Allow E-Y to use speech recognition."
        }
      ],
      [
        "@sentry/react-native/expo",
        {
          "organization": "e-y",
          "project": "mobile"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "14113467-98b8-43ff-8402-0c324cf731f7"
      }
    },
    "owner": "eternity-wallet",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/14113467-98b8-43ff-8402-0c324cf731f7"
    }
  }
}
