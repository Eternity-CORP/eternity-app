# npm configuration для Supply Chain Security

# Включить проверку целостности пакетов
package-lock=true
package-lock-only=false

# Автоматическая проверка подписей пакетов (npm 9+)
audit=true

# Строгий режим установки - использовать только lock-файл
ci=true

# Логирование
loglevel=warn

# Безопасность
ignore-scripts=false

# Для CI/CD - отключить обновления notifier
update-notifier=false

# Кэширование
cache-min=3600

# Registry settings (можно использовать приватный registry)
# registry=https://registry.npmjs.org/

# Включить строгие проверки peer dependencies
strict-peer-dependencies=false

# Автоматическая проверка уязвимостей после установки
audit-level=moderate
