{
  "name": "@eternity-wallet/backend",
  "version": "1.0.0",
  "description": "Eternity Wallet Backend API - NestJS",
  "main": "dist/main.js",
  "scripts": {
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:prod": "node dist/main",
    "build": "nest build",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "migration:generate": "typeorm-ts-node-commonjs -d database/data-source.ts migration:generate database/migrations/AutoSchema",
    "migration:run": "typeorm-ts-node-commonjs -d database/data-source.ts migration:run",
    "migration:revert": "typeorm-ts-node-commonjs -d database/data-source.ts migration:revert"
  },
  "dependencies": {
    "@nestjs/bull": "^11.0.4",
    "@nestjs/common": "^11.1.7",
    "@nestjs/config": "^4.0.2",
