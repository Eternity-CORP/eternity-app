# Environment configuration for Eternity Wallet Backend (NestJS)
# Copy to .env and fill mandatory values.

# Runtime
NODE_ENV=development
PORT=3000

# Database (MANDATORY)
# Use full connection string: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgres://postgres:postgres@localhost:5432/eternity_wallet
DATABASE_SSL=false

# Authentication (MANDATORY)
# Minimum 32 chars
JWT_SECRET=change-this-in-prod-32-chars-minimum________________________________

# Redis (OPTIONAL - comment out if not using Redis)
# REDIS_URL=redis://localhost:6379

# Ethereum RPC (MANDATORY)
ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# Alchemy Webhook Secret (MANDATORY)
ALCHEMY_WEBHOOK_SECRET=replace_with_real_secret

# Shard System (OPTIONAL - defaults provided)
MIN_TX_AMOUNT_FOR_SHARD=0.001
MAX_SHARDS_PER_DAY=3

# Cross-Chain Aggregators (RECOMMENDED for production)
# LiFi - https://li.fi/ - Register as integrator
LIFI_API_KEY=your_lifi_api_key_here
# Rango - https://rango.exchange/ - Register for API access
RANGO_API_KEY=your_rango_api_key_here
# Socket - https://socket.tech/ - Optional for MVP
SOCKET_API_KEY=your_socket_api_key_here

# Testnet Configuration (for development)
TESTNET_PRIVATE_KEY=your_testnet_private_key_here
SEPOLIA_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
POLYGON_MUMBAI_RPC_URL=https://polygon-mumbai.g.alchemy.com/v2/YOUR_KEY
