# Environment configuration for Eternity Wallet Backend (NestJS)
# Copy to .env and fill mandatory values.

# Runtime
NODE_ENV=development
PORT=3000

# Database (MANDATORY)
# Use full connection string: postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=postgres://postgres:postgres@localhost:5432/eternity_wallet
DATABASE_SSL=false

# Authentication (MANDATORY)
# Minimum 32 chars
JWT_SECRET=change-this-in-prod-32-chars-minimum________________________________

# Redis (MANDATORY)
REDIS_URL=redis://localhost:6379

# Ethereum RPC (MANDATORY)
ETHEREUM_RPC_URL=https://eth-mainnet.g.alchemy.com/v2/YOUR_KEY

# Alchemy Webhook Secret (MANDATORY)
ALCHEMY_WEBHOOK_SECRET=replace_with_real_secret
