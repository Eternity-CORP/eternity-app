# Blockchain & ethers.js v6 Rules

## ethers.js v6 Migration
> **Important**: We use ethers.js v6, NOT v5. Syntax has changed significantly.

### v6 Changes from v5
```typescript
// v6 syntax (CORRECT)
import { ethers, formatEther, parseEther, Contract } from 'ethers';

const provider = new ethers.JsonRpcProvider(rpcUrl);
const balance = await provider.getBalance(address);
const formatted = formatEther(balance); // Returns string

// v5 syntax (INCORRECT - don't use)
// const provider = new ethers.providers.JsonRpcProvider(rpcUrl);
// const formatted = ethers.utils.formatEther(balance);
```

### Provider Setup
```typescript
import { ethers, JsonRpcProvider, WebSocketProvider } from 'ethers';

// HTTP Provider
const provider = new JsonRpcProvider(process.env.ETHEREUM_RPC_URL);

// WebSocket Provider (for subscriptions)
const wsProvider = new WebSocketProvider(process.env.ETHEREUM_WS_URL);

// With network specification
const provider = new JsonRpcProvider(rpcUrl, {
  chainId: 1,
  name: 'mainnet',
});

// Provider caching pattern
const providerCache = new Map<string, JsonRpcProvider>();

function getProvider(chainId: number): JsonRpcProvider {
  const key = `chain-${chainId}`;
  if (!providerCache.has(key)) {
    providerCache.set(key, new JsonRpcProvider(getRpcUrl(chainId)));
  }
  return providerCache.get(key)!;
}
```

### Wallet Operations
```typescript
import { Wallet, HDNodeWallet, Mnemonic } from 'ethers';

// Create random wallet
const wallet = Wallet.createRandom();

// From mnemonic (v6 syntax)
const mnemonic = Mnemonic.fromPhrase(seedPhrase);
const hdNode = HDNodeWallet.fromMnemonic(mnemonic);
const wallet = hdNode.deriveChild(0);

// From private key
const wallet = new Wallet(privateKey, provider);

// Sign transaction
const signedTx = await wallet.signTransaction({
  to: recipient,
  value: parseEther('1.0'),
  gasLimit: 21000n, // Use BigInt for gas
});

// Send transaction
const tx = await wallet.sendTransaction({
  to: recipient,
  value: parseEther('0.1'),
});
const receipt = await tx.wait(); // Wait for confirmation
```

### Contract Interactions
```typescript
import { Contract, Interface } from 'ethers';

// ERC20 ABI (minimal)
const ERC20_ABI = [
  'function balanceOf(address owner) view returns (uint256)',
  'function transfer(address to, uint256 amount) returns (bool)',
  'function approve(address spender, uint256 amount) returns (bool)',
  'function allowance(address owner, address spender) view returns (uint256)',
  'event Transfer(address indexed from, address indexed to, uint256 value)',
];

// Read-only contract (no signer)
const token = new Contract(tokenAddress, ERC20_ABI, provider);
const balance = await token.balanceOf(userAddress);

// With signer (for transactions)
const tokenWithSigner = new Contract(tokenAddress, ERC20_ABI, wallet);
const tx = await tokenWithSigner.transfer(recipient, parseUnits('100', 6));
await tx.wait();
```

### BigInt Handling (v6)
```typescript
import { parseEther, formatEther, parseUnits, formatUnits } from 'ethers';

// v6 returns BigInt, not BigNumber
const weiAmount = parseEther('1.5'); // 1500000000000000000n (BigInt)
const ethAmount = formatEther(weiAmount); // "1.5" (string)

// For tokens with decimals
const usdcAmount = parseUnits('100', 6); // 100000000n (6 decimals)
const formatted = formatUnits(usdcAmount, 6); // "100.0"

// BigInt arithmetic
const total = amount1 + amount2; // Use + not .add()
const double = amount * 2n; // Multiply with BigInt literal

// Comparison
if (balance >= requiredAmount) { ... }

// Convert to string for APIs
const amountString = weiAmount.toString();
```

### Gas Estimation
```typescript
// Estimate gas
const gasEstimate = await provider.estimateGas({
  from: wallet.address,
  to: recipient,
  value: parseEther('1.0'),
});

// Add buffer (20%)
const gasLimit = (gasEstimate * 120n) / 100n;

// Get fee data (EIP-1559)
const feeData = await provider.getFeeData();
const { maxFeePerGas, maxPriorityFeePerGas, gasPrice } = feeData;

// Build transaction with EIP-1559
const tx = {
  to: recipient,
  value: parseEther('1.0'),
  gasLimit,
  maxFeePerGas,
  maxPriorityFeePerGas,
};
```

### Error Handling
```typescript
import { isError } from 'ethers';

try {
  const tx = await wallet.sendTransaction(txData);
  await tx.wait();
} catch (error) {
  // v6 error checking
  if (isError(error, 'INSUFFICIENT_FUNDS')) {
    throw new InsufficientBalanceError();
  }
  if (isError(error, 'NONCE_EXPIRED')) {
    // Retry with fresh nonce
  }
  if (isError(error, 'REPLACEMENT_UNDERPRICED')) {
    // Increase gas price
  }
  if (isError(error, 'CALL_EXCEPTION')) {
    // Contract reverted
    console.error('Revert reason:', error.reason);
  }
  throw error;
}
```

### Transaction Monitoring
```typescript
// Wait for confirmations
const receipt = await tx.wait(3); // Wait for 3 confirmations

// Check transaction status
if (receipt.status === 0) {
  throw new Error('Transaction reverted');
}

// Listen for events
const filter = token.filters.Transfer(fromAddress, null);
token.on(filter, (from, to, value, event) => {
  console.log('Transfer detected:', { from, to, value: formatEther(value) });
});

// Remove listener
token.off(filter);
```

### Multi-Chain Support
```typescript
const CHAIN_CONFIG: Record<number, ChainConfig> = {
  1: { name: 'Ethereum', rpcUrl: process.env.ETH_RPC, symbol: 'ETH' },
  137: { name: 'Polygon', rpcUrl: process.env.POLYGON_RPC, symbol: 'MATIC' },
  42161: { name: 'Arbitrum', rpcUrl: process.env.ARB_RPC, symbol: 'ETH' },
  10: { name: 'Optimism', rpcUrl: process.env.OP_RPC, symbol: 'ETH' },
  8453: { name: 'Base', rpcUrl: process.env.BASE_RPC, symbol: 'ETH' },
};

function getChainProvider(chainId: number): JsonRpcProvider {
  const config = CHAIN_CONFIG[chainId];
  if (!config) throw new Error(`Unsupported chain: ${chainId}`);
  return new JsonRpcProvider(config.rpcUrl);
}
```

### Security Best Practices
```typescript
// NEVER log private keys or mnemonics
console.log('Wallet created'); // Good
console.log('Key:', privateKey); // NEVER DO THIS

// Validate addresses
import { isAddress, getAddress } from 'ethers';

function validateAddress(address: string): string {
  if (!isAddress(address)) {
    throw new Error('Invalid Ethereum address');
  }
  return getAddress(address); // Returns checksummed address
}

// Validate transaction amounts
function validateAmount(amount: string, decimals: number): bigint {
  const parsed = parseUnits(amount, decimals);
  if (parsed <= 0n) {
    throw new Error('Amount must be positive');
  }
  return parsed;
}
```

