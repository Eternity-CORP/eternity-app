# React Native & Expo Rules

## Tech Stack
- React Native with Expo SDK 51+
- TypeScript strict mode
- React Navigation v6
- Zustand for state management
- ethers.js v6 for blockchain
- expo-secure-store for sensitive data

## Component Structure

### Functional Components Only
```typescript
// Good - Functional component with TypeScript
interface WalletCardProps {
  balance: string;
  address: string;
  onPress?: () => void;
}

export function WalletCard({ balance, address, onPress }: WalletCardProps) {
  return (
    <TouchableOpacity onPress={onPress} style={styles.container}>
      <Text style={styles.balance}>{balance}</Text>
      <Text style={styles.address}>{truncateAddress(address)}</Text>
    </TouchableOpacity>
  );
}

// Avoid - Class components
class WalletCard extends React.Component { ... }
```

### Hook Patterns
```typescript
// Custom hook with proper typing
function useWalletBalance(address: string) {
  const [balance, setBalance] = useState<string | null>(null);
  const [isLoading, setIsLoading] = useState(true);
  const [error, setError] = useState<Error | null>(null);

  useEffect(() => {
    let cancelled = false;
    
    async function fetchBalance() {
      try {
        setIsLoading(true);
        const result = await getBalance(address);
        if (!cancelled) setBalance(result);
      } catch (err) {
        if (!cancelled) setError(err as Error);
      } finally {
        if (!cancelled) setIsLoading(false);
      }
    }
    
    fetchBalance();
    return () => { cancelled = true; };
  }, [address]);

  return { balance, isLoading, error };
}
```

## Styling

### Use StyleSheet.create
```typescript
// Good
const styles = StyleSheet.create({
  container: {
    flex: 1,
    padding: 16,
    backgroundColor: '#0D0D0D',
  },
  title: {
    fontSize: 24,
    fontWeight: '600',
