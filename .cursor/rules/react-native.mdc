## State Management

### Zustand Store Pattern
```typescript
interface WalletState {
  address: string | null;
  balance: string;
  isLoading: boolean;
  setAddress: (address: string) => void;
  refreshBalance: () => Promise<void>;
}

export const useWalletStore = create<WalletState>((set, get) => ({
  address: null,
  balance: '0',
  isLoading: false,
  setAddress: (address) => set({ address }),
  refreshBalance: async () => {
    const { address } = get();
    if (!address) return;
    set({ isLoading: true });
    try {
      const balance = await fetchBalance(address);
      set({ balance, isLoading: false });
    } catch {
      set({ isLoading: false });
    }
  },
}));
```

## Performance

### Memoization
```typescript
// Memoize expensive computations
const formattedBalance = useMemo(
  () => formatCurrency(balance, decimals),
  [balance, decimals]
);

// Memoize callbacks passed to children
const handlePress = useCallback(() => {
  navigation.navigate('Details', { id });
}, [navigation, id]);

// Memoize list items
const renderItem = useCallback(({ item }: { item: Transaction }) => (
  <TransactionItem transaction={item} />
), []);
```

### FlatList Optimization
```typescript
<FlatList
  data={transactions}
  keyExtractor={(item) => item.hash}
  renderItem={renderItem}
  initialNumToRender={10}
  maxToRenderPerBatch={10}
  windowSize={5}
  removeClippedSubviews={true}
  getItemLayout={(_, index) => ({
    length: ITEM_HEIGHT,
    offset: ITEM_HEIGHT * index,
    index,
  })}
/>
```

## Security

### Sensitive Data Storage
```typescript
// Use expo-secure-store for sensitive data
import * as SecureStore from 'expo-secure-store';

// Store private key
await SecureStore.setItemAsync('privateKey', encryptedKey, {
  keychainAccessible: SecureStore.WHEN_UNLOCKED_THIS_DEVICE_ONLY,
});

// Never log sensitive data
console.log('Wallet created'); // Good
console.log('Private key:', key); // NEVER DO THIS
```

### Biometric Authentication
```typescript
import * as LocalAuthentication from 'expo-local-authentication';

async function authenticateUser(): Promise<boolean> {
  const hasHardware = await LocalAuthentication.hasHardwareAsync();
  if (!hasHardware) return false;
  
  const result = await LocalAuthentication.authenticateAsync({
    promptMessage: 'Authenticate to access wallet',
    fallbackLabel: 'Use PIN',
  });
  
  return result.success;
}
```

