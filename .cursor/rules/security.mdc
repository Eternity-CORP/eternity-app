## Authentication & Authorization

### JWT Best Practices
```typescript
// Short-lived access tokens
const accessToken = jwt.sign(payload, secret, { expiresIn: '15m' });

// Longer refresh tokens (stored securely)
const refreshToken = jwt.sign(payload, refreshSecret, { expiresIn: '7d' });

// Always verify tokens
try {
  const decoded = jwt.verify(token, secret);
} catch (error) {
  throw new UnauthorizedException('Invalid token');
}
```

### Biometric Authentication
```typescript
// Always require auth for sensitive actions
async function sendTransaction(tx: TransactionRequest): Promise<string> {
  // Step 1: Require authentication
  const authenticated = await biometricService.authenticate({
    promptMessage: 'Authenticate to send transaction',
  });
  
  if (!authenticated) {
    throw new AuthenticationError('Authentication required');
  }
  
  // Step 2: Proceed with transaction
  return walletService.sign(tx);
}
```

### Rate Limiting
```typescript
// Apply rate limits to sensitive endpoints
@Throttle({ default: { limit: 5, ttl: 60000 } })
@Post('login')
async login() { ... }

@Throttle({ default: { limit: 10, ttl: 60000 } })
@Post('transactions')
async createTransaction() { ... }
```

## Transaction Security

### Verify Before Signing
```typescript
async function prepareAndSignTransaction(params: TxParams) {
  // 1. Validate recipient
  const toAddress = validateAddress(params.to);
  
  // 2. Validate amount
  const amount = validateAmount(params.amount, 18);
  
  // 3. Check balance
  const balance = await provider.getBalance(wallet.address);
  if (balance < amount) {
    throw new InsufficientBalanceError();
  }
  
  // 4. Estimate gas and check affordability
  const gasEstimate = await provider.estimateGas({ to: toAddress, value: amount });
  const feeData = await provider.getFeeData();
  const totalCost = amount + (gasEstimate * feeData.maxFeePerGas!);
  
  if (balance < totalCost) {
    throw new InsufficientBalanceError('Cannot afford gas fees');
  }
  
  // 5. Sign only after all validations pass
  return wallet.signTransaction({ ... });
}
```

### Prevent Double Spending
```typescript
// Use nonce management
async function getNextNonce(address: string): Promise<number> {
  const [onChainNonce, pendingNonce] = await Promise.all([
    provider.getTransactionCount(address, 'latest'),
    provider.getTransactionCount(address, 'pending'),
  ]);
  
  return Math.max(onChainNonce, pendingNonce);
}
```

## API Security

### HTTPS Only
```typescript
// Reject non-HTTPS in production
if (process.env.NODE_ENV === 'production') {
  app.use((req, res, next) => {
    if (req.headers['x-forwarded-proto'] !== 'https') {
      return res.redirect(`https://${req.hostname}${req.url}`);
    }
    next();
  });
}
```

### CORS Configuration
```typescript
app.enableCors({
  origin: process.env.ALLOWED_ORIGINS?.split(',') || [],
  methods: ['GET', 'POST', 'PUT', 'DELETE'],
  credentials: true,
});
```

### Security Headers
```typescript
import helmet from 'helmet';

app.use(helmet());
app.use(helmet.contentSecurityPolicy({
  directives: {
    defaultSrc: ["'self'"],
    scriptSrc: ["'self'"],
    styleSrc: ["'self'", "'unsafe-inline'"],
  },
}));
```

