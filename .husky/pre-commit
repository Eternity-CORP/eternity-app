#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

echo "🔍 Running pre-commit checks..."

# Check if backend files are being committed
BACKEND_CHANGED=$(git diff --cached --name-only | grep -E '^backend/src/' || true)

if [ -n "$BACKEND_CHANGED" ]; then
  echo "🧪 Running backend tests..."
  cd backend && npm test --silent
  if [ $? -ne 0 ]; then
    echo ""
    echo "❌ Backend tests failed!"
    echo "   Please fix failing tests before committing."
    echo ""
    exit 1
  fi
  cd ..
  echo "✅ Backend tests passed"
fi

# Check if docs files are being committed
DOCS_CHANGED=$(git diff --cached --name-only | grep -E '^docs/|^backend/src/|^mobile/src/' || true)

if [ -n "$DOCS_CHANGED" ]; then
  echo "📋 Running documentation consistency check..."
  npm run docs:check 2>/dev/null || true
fi

echo "✅ Pre-commit checks completed"
