#!/usr/bin/env sh
. "$(dirname -- "$0")/_/husky.sh"

# Check if docs files are being committed
DOCS_CHANGED=$(git diff --cached --name-only | grep -E '^docs/|^backend/src/|^mobile/src/' || true)

if [ -n "$DOCS_CHANGED" ]; then
  echo "📋 Running documentation consistency check..."
  npm run docs:check
  
  if [ $? -ne 0 ]; then
    echo ""
    echo "❌ Documentation consistency check failed!"
    echo "   Please update docs/TRACEABILITY.md and fix issues."
    echo "   Run: npm run docs:check"
    echo ""
    exit 1
  fi
fi
