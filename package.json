{
  "name": "e-y",
  "version": "0.1.0",
  "private": true,
  "description": "E-Y - Crypto wallet with BLIK codes",
  "scripts": {
    "start": "./scripts/dev.sh",
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "mobile": "concurrently --raw \"pnpm --filter @e-y/api start:dev\" \"pnpm --filter @e-y/mobile start\"",
    "mobile:go": "concurrently --raw \"pnpm --filter @e-y/api start:dev\" \"pnpm --filter @e-y/mobile start:go\"",
    "mobile:ios": "pnpm --filter @e-y/mobile ios",
    "mobile:android": "pnpm --filter @e-y/mobile android",
    "mobile:only": "pnpm --filter @e-y/mobile start",
    "api": "pnpm --filter @e-y/api start:dev",
    "test:api": "pnpm --filter @e-y/api test",
    "test:api:e2e": "pnpm --filter @e-y/api test:e2e",
    "test:preferences": "pnpm --filter @e-y/api test -- --testPathPattern=preferences",
    "test:all": "npx tsx scripts/tests/index.ts",
    "test:module": "npx tsx scripts/tests/index.ts",
    "eas-build-pre-install": "cd apps/mobile && bash eas-build-pre-install.sh"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "socket.io-client": "^4.8.3",
    "turbo": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@9.1.0",
  "pnpm": {
    "overrides": {
      "react": "19.1.0",
      "react-dom": "19.1.0"
    }
  }
}
