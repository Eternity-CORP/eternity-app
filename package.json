{
  "name": "eternity-wallet-monorepo",
  "version": "1.0.0",
  "description": "Eternity Wallet - A crypto wallet app with payment gateway functionality",
  "private": true,
  "workspaces": [
    "mobile",
    "backend",
    "shared"
  ],
  "scripts": {
    "dev": "concurrently \"npm run backend\" \"npm run mobile\" --names \"🔧,📱\" --prefix-colors \"blue,magenta\"",
    "dev:ios": "concurrently \"npm run backend\" \"npm run mobile:ios\" --names \"🔧,📱\" --prefix-colors \"blue,magenta\"",
    "dev:android": "concurrently \"npm run backend\" \"npm run mobile:android\" --names \"🔧,📱\" --prefix-colors \"blue,magenta\"",
    "dev:web": "concurrently \"npm run backend\" \"npm run mobile:web\" --names \"🔧,📱\" --prefix-colors \"blue,magenta\"",
    "mobile": "cd mobile && npm start",
    "mobile:ios": "cd mobile && npm run ios",
    "mobile:android": "cd mobile && npm run android",
    "mobile:web": "cd mobile && npm run web",
    "backend": "cd backend && npm run start:dev",
    "install:all": "npm install && npm install --workspace=mobile && npm install --workspace=backend && npm install --workspace=shared",
    "clean": "rm -rf node_modules mobile/node_modules backend/node_modules shared/node_modules",
    "lint": "npm run lint --workspaces",
    "test": "npm run test --workspaces",
    "test:e2e": "vitest run",
    "docs:check": "npx tsx scripts/check-docs-consistency.ts",
    "docs:sync": "echo '📋 Run docs:check first, then update TRACEABILITY.md manually'",
    "landing": "cd landing && npm run dev",
    "landing:build": "cd landing && npm run build"
  },
  "keywords": [
    "crypto",
    "wallet",
    "ethereum",
    "blockchain",
    "payment-gateway",
    "react-native",
    "nestjs"
  ],
  "author": "Your Name",
  "license": "MIT",
  "devDependencies": {
    "@types/react": "~19.1.1",
    "typescript": "^5.3.3",
    "tsx": "^4.7.0",
    "@types/node": "^20.11.0",
    "vitest": "^1.6.0",
    "concurrently": "^8.2.2"
  },
  "dependencies": {
    "@react-native-picker/picker": "2.11.1",
    "dotenv": "^16.4.0",
    "expo-blur": "~15.0.8",
    "expo-haptics": "~15.0.8",
    "lottie-react-native": "~7.3.1",
    "react-native-safe-area-context": "~5.6.0"
  }
}
