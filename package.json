{
  "name": "e-y",
  "version": "0.1.0",
  "private": true,
  "description": "E-Y - Crypto wallet with BLIK codes",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "mobile": "pnpm --filter @e-y/mobile start",
    "mobile:go": "pnpm --filter @e-y/mobile start:go",
    "mobile:ios": "pnpm --filter @e-y/mobile ios",
    "mobile:android": "pnpm --filter @e-y/mobile android",
    "eas-build-pre-install": "cd apps/mobile && bash eas-build-pre-install.sh"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.3.3"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@9.1.0"
}
